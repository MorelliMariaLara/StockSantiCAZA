@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="brand">
    <strong>StockSantiCAZA</strong>
    <small>Armería · Control trazable</small>
</div>

@if (AuthService.UsuarioActual is not null)
{
    <div class="user-chip">
        <strong>@AuthService.UsuarioActual.Nombre</strong>
        <small>@(AuthService.UsuarioActual.EsAdministrador ? "Administrador" : "Vendedor")</small>
    </div>

    <nav class="nav-menu">
        @if (AuthService.UsuarioActual.EsAdministrador)
        {
            <NavLink href="" Match="NavLinkMatch.All" @onclick="NotificarNavegacion">
                <span class="nav-icon">◆</span> Dashboard
            </NavLink>
        }
        <NavLink href="ventas/nueva" @onclick="NotificarNavegacion">
            <span class="nav-icon">◆</span> Nueva venta
        </NavLink>
        <NavLink href="ventas" @onclick="NotificarNavegacion">
            <span class="nav-icon">◆</span> Historial ventas
        </NavLink>
        <NavLink href="clientes" @onclick="NotificarNavegacion">
            <span class="nav-icon">◆</span> Clientes
        </NavLink>
        <NavLink href="stock" @onclick="NotificarNavegacion">
            <span class="nav-icon">◆</span> Stock
        </NavLink>
        @if (AuthService.UsuarioActual.EsAdministrador)
        {
            <NavLink href="proveedores" @onclick="NotificarNavegacion">
                <span class="nav-icon">◆</span> Proveedores
            </NavLink>
            <NavLink href="reportes" @onclick="NotificarNavegacion">
                <span class="nav-icon">◆</span> Reportes
            </NavLink>
            <NavLink href="usuarios" @onclick="NotificarNavegacion">
                <span class="nav-icon">◆</span> Usuarios
            </NavLink>
        }
    </nav>

    <button class="button ghost logout-button" @onclick="CerrarSesionAsync">Cerrar sesión</button>
}

@code {
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private async Task NotificarNavegacion()
    {
        if (OnNavigate.HasDelegate)
        {
            await OnNavigate.InvokeAsync();
        }
    }

    private async Task CerrarSesionAsync()
    {
        await NotificarNavegacion();
        await AuthService.CerrarSesionAsync();
        Navigation.NavigateTo("/login", true);
    }
}
