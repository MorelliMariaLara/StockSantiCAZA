@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="brand">
    <strong>StockSantiCAZA</strong>
    <small>Armería · Control trazable</small>
</div>

@if (AuthService.UsuarioActual is not null)
{
    <div class="user-chip">
        <strong>@AuthService.UsuarioActual.Nombre</strong>
        <small>@(AuthService.UsuarioActual.EsAdministrador ? "Administrador" : "Vendedor")</small>
    </div>

    <nav class="nav-menu">
        <NavLink href="" Match="NavLinkMatch.All"><span class="nav-icon">◆</span> Dashboard</NavLink>
        <NavLink href="clientes"><span class="nav-icon">◆</span> Clientes</NavLink>
        <NavLink href="stock"><span class="nav-icon">◆</span> Stock</NavLink>
        <NavLink href="ventas"><span class="nav-icon">◆</span> Ventas</NavLink>
        @if (AuthService.UsuarioActual.EsAdministrador)
        {
            <NavLink href="reportes"><span class="nav-icon">◆</span> Reportes</NavLink>
            <NavLink href="usuarios"><span class="nav-icon">◆</span> Usuarios</NavLink>
        }
    </nav>

    <button class="button ghost logout-button" @onclick="CerrarSesionAsync">Cerrar sesión</button>
}

@code {
    private async Task CerrarSesionAsync()
    {
        await AuthService.CerrarSesionAsync();
        Navigation.NavigateTo("/login", true);
    }
}
