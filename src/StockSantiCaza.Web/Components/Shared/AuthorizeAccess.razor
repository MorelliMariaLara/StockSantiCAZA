@using StockSantiCaza.Web.Services.Auth
@inject IAuthService AuthService
@inject NavigationManager Navigation

@if (Autorizado)
{
    @ChildContent
}
else if (Redirigiendo)
{
    <p>Redirigiendo...</p>
}
else if (!string.IsNullOrWhiteSpace(Mensaje))
{
    <section class="panel">
        <div class="alert alert-danger">@Mensaje</div>
    </section>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool RequiereAdministrador { get; set; }

    [Parameter]
    public ModuloSistema? Modulo { get; set; }

    private bool Autorizado { get; set; }

    private bool Redirigiendo { get; set; }

    private string? Mensaje { get; set; }

    protected override void OnInitialized()
    {
        if (AuthService.UsuarioActual is null)
        {
            Redirigiendo = true;
            return;
        }

        if (RequiereAdministrador && !AuthService.UsuarioActual.EsAdministrador)
        {
            Mensaje = "No tiene permisos para acceder a esta sección. Solo administradores.";
            return;
        }

        if (Modulo.HasValue && !AuthService.UsuarioActual.PuedeAcceder(Modulo.Value))
        {
            Mensaje = "No tiene permisos para acceder a este módulo.";
            return;
        }

        Autorizado = true;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (Redirigiendo)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        if (!Autorizado && AuthService.UsuarioActual is not null && Modulo.HasValue)
        {
            Navigation.NavigateTo(AuthService.UsuarioActual.EsAdministrador ? "/" : "/ventas/nueva");
        }
    }
}
