@if (Visible)
{
    <div class="confirm-backdrop no-print" @onclick="Cancelar">
        <div class="confirm-panel panel" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <h3>@Title</h3>
            <p>@Message</p>
            <div class="actions">
                <button type="button" class="button btn-delete" @onclick="Confirmar">@ConfirmText</button>
                <button type="button" class="button ghost" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public string Title { get; set; } = "Confirmar eliminación";

    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public string ConfirmText { get; set; } = "Borrar";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private Task Confirmar() => OnConfirm.InvokeAsync();

    private Task Cancelar() => OnCancel.InvokeAsync();
}
