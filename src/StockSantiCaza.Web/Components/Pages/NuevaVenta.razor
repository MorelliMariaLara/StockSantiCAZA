@page "/ventas/nueva"
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IVentasService VentasService
@inject IUsuariosService UsuariosService
@inject IAuthService AuthService
@inject IJSRuntime Js

<AuthorizeAccess Modulo="ModuloSistema.Ventas">
    <PageTitle>Nueva venta - StockSantiCAZA</PageTitle>

    <h1>Nueva venta</h1>
    <p class="page-intro">Seleccione producto y cliente, luego confirme con <strong>Guardar venta</strong>. El formulario se limpia automáticamente para la siguiente operación.</p>

    @if (cargando)
    {
        <p>Cargando datos comerciales...</p>
    }
    else
    {
        <div>
            @if (!string.IsNullOrWhiteSpace(mensajeExito))
            {
                <div class="alert alert-success venta-flash">
                    <strong>@mensajeExito</strong>
                </div>
            }

            @if (errores.Count > 0)
            {
                <div class="alert alert-danger">
                    <strong>No se pudo completar la operación</strong>
                    <ul>
                        @foreach (var error in errores)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <section class="panel venta-rapida step-panel" id="venta-rapida">
                <h2><span class="step-badge">1</span> Producto</h2>
                <div class="grid product-entry">
                    <label>
                        Buscar producto
                        <InputText class="input" @bind-Value="busquedaProducto" placeholder="SKU, nombre, marca, calibre..." />
                    </label>

                    <label>
                        Producto
                        <InputSelect class="input" @bind-Value="productoSeleccionadoId" @bind-Value:after="ActualizarProductoSeleccionado">
                            <option value="0">Seleccione...</option>
                            @foreach (var producto in ProductosFiltrados)
                            {
                                <option value="@producto.Id">@producto.Sku - @producto.Nombre (@producto.StockActual) - @MonedaHelper.FormatearUsd(producto.PrecioUnitario)</option>
                            }
                        </InputSelect>
                    </label>

                    <label>
                        Cantidad
                        <InputNumber class="input" @bind-Value="cantidad" />
                    </label>

                    <label>
                        Precio USD
                        <InputNumber class="input" @bind-Value="precioUnitario" />
                    </label>
                </div>

                @if (productoSeleccionado is not null && productoSeleccionado.StockActual <= productoSeleccionado.StockMinimo)
                {
                    <div class="product-alerts">
                        <span class="badge danger">Stock mínimo: @productoSeleccionado.StockActual/@productoSeleccionado.StockMinimo</span>
                    </div>
                }

                <div class="actions">
                    <button type="button" class="button" @onclick="AgregarItem" disabled="@(productoSeleccionadoId <= 0)">Agregar al detalle</button>
                    <small class="hint">Si olvida agregar, el producto seleccionado se incluye al guardar.</small>
                </div>

                @if (items.Count > 0)
                {
                    <div class="table-wrap venta-detalle-mini">
                        <table>
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th>Cant.</th>
                                    <th>Total USD</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in items)
                                {
                                    <tr>
                                        <td>@item.Producto.Nombre</td>
                                        <td>@item.Cantidad</td>
                                        <td>@MonedaHelper.FormatearUsd(item.TotalEstimado)</td>
                                        <td><button type="button" class="link-button" @onclick="() => QuitarItem(item)">Quitar</button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="totals venta-total-inline">
                        <strong>Total: @MonedaHelper.FormatearUsd(Total)</strong>
                    </div>
                }
            </section>

            <section class="panel step-panel">
                <div class="section-header">
                    <div>
                        <h2><span class="step-badge">2</span> Cliente</h2>
                        <p>Busque o cree el cliente de la venta.</p>
                    </div>
                    <button type="button" class="button ghost" @onclick="AbrirNuevoCliente">+ Nuevo cliente</button>
                </div>

                <div class="grid sale-header">
                    <label>
                        Buscar cliente
                        <InputText class="input" @bind-Value="busquedaCliente" placeholder="Nombre, DNI/CUIT, teléfono..." />
                    </label>

                    <label>
                        Cliente
                        <InputSelect class="input" @bind-Value="clienteIdSeleccionado" @bind-Value:after="ActualizarClienteSeleccionado">
                            <option value="0">Seleccione...</option>
                            @foreach (var cliente in ClientesFiltrados)
                            {
                                <option value="@cliente.Id">@FormatearCliente(cliente)</option>
                            }
                        </InputSelect>
                    </label>

                    @if (AuthService.UsuarioActual?.EsAdministrador == true)
                    {
                        <label>
                            Vendedor
                            <InputSelect class="input" @bind-Value="vendedorIdSeleccionado">
                                <option value="0">Seleccione...</option>
                                @foreach (var vendedor in vendedores)
                                {
                                    <option value="@vendedor.Id">@vendedor.Nombre (@vendedor.Rol)</option>
                                }
                            </InputSelect>
                        </label>
                    }
                    else
                    {
                        <label>
                            Vendedor
                            <input class="input" value="@AuthService.UsuarioActual?.Nombre" disabled />
                        </label>
                    }

                </div>

                @if (clienteSeleccionado is not null)
                {
                    <div class="alert alert-success client-selected">
                        <strong>@clienteSeleccionado.NombreRazonSocial</strong>
                        @if (!ClienteHelper.EsDniInterno(clienteSeleccionado.DniCuit))
                        {
                            <span> — @clienteSeleccionado.DniCuit</span>
                        }
                    </div>
                }

                @if (mostrarFormularioCliente)
                {
                    <div class="subpanel cliente-venta-nuevo">
                        <div class="section-header">
                            <h3>Alta rápida de cliente</h3>
                            <button type="button" class="link-button" @onclick="CerrarNuevoCliente">Cancelar</button>
                        </div>
                        <p class="hint">El DNI/CUIT es opcional. Sin documento se genera un identificador interno.</p>
                        <div class="grid client-form">
                            <label>
                                Nombre / razón social *
                                <InputText class="input" @bind-Value="clienteNuevo.Nombre" />
                            </label>
                            <label>
                                DNI/CUIT
                                <InputText class="input" @bind-Value="clienteNuevo.DniCuit" placeholder="Opcional" />
                            </label>
                            <label>
                                Teléfono
                                <InputText class="input" @bind-Value="clienteNuevo.Telefono" placeholder="Opcional" />
                            </label>
                            <label>
                                Domicilio
                                <InputText class="input" @bind-Value="clienteNuevo.Domicilio" placeholder="Opcional" />
                            </label>
                        </div>
                        <div class="actions">
                            <button type="button" class="button" @onclick="GuardarNuevoClienteAsync" disabled="@procesandoCliente">
                                @(procesandoCliente ? "Guardando..." : "Guardar y seleccionar")
                            </button>
                        </div>
                    </div>
                }
            </section>

            <section class="panel venta-guardar step-panel" id="venta-guardar">
                <h2><span class="step-badge">3</span> Confirmar venta</h2>

                <div class="grid sale-header">
                    <label>
                        Observaciones (opcional)
                        <InputText class="input" @bind-Value="form.Observaciones" placeholder="Opcional" />
                    </label>
                </div>

                <ul class="sale-checklist">
                    <li class="@(TieneProductos ? "ok" : "pending")">
                        @(TieneProductos ? "✓" : "○") Producto en la venta
                    </li>
                    <li class="@(ClienteListo ? "ok" : "pending")">
                        @(ClienteListo ? "✓" : "○") Cliente seleccionado
                    </li>
                </ul>

                <div class="venta-acciones-finales">
                    <button type="button" class="button primary button-xl" disabled="@(!PuedeConfirmarVenta)" @onclick="ConfirmarVentaAsync">
                        @(procesando ? "Guardando..." : "Guardar venta")
                    </button>
                </div>
                <p class="sale-hint">Tras guardar, el formulario se limpia automáticamente para la próxima venta.</p>
            </section>
        </div>
    }
</AuthorizeAccess>

@code {
    private readonly NuevaVentaRequest form = new();
    private readonly List<LineaVentaVm> items = [];
    private readonly List<string> errores = [];
    private List<Cliente> clientes = [];
    private List<Producto> productos = [];
    private List<Usuario> vendedores = [];
    private Cliente? clienteSeleccionado;
    private Producto? productoSeleccionado;
    private string? mensajeExito;
    private bool cargando = true;
    private bool procesando;
    private bool procesandoCliente;
    private bool mostrarFormularioCliente;
    private string busquedaProducto = string.Empty;
    private string busquedaCliente = string.Empty;
    private int productoSeleccionadoId;
    private int clienteIdSeleccionado;
    private int vendedorIdSeleccionado;
    private int cantidad = 1;
    private decimal precioUnitario;
    private decimal descuentoLinea;
    private ClienteNuevoForm clienteNuevo = new();

    private IEnumerable<Producto> ProductosFiltrados
    {
        get
        {
            var filtrados = (string.IsNullOrWhiteSpace(busquedaProducto)
                    ? productos
                    : productos.Where(x =>
                        x.Sku.Contains(busquedaProducto, StringComparison.OrdinalIgnoreCase)
                        || x.Nombre.Contains(busquedaProducto, StringComparison.OrdinalIgnoreCase)
                        || (x.Marca?.Contains(busquedaProducto, StringComparison.OrdinalIgnoreCase) ?? false)
                        || (x.Calibre?.Contains(busquedaProducto, StringComparison.OrdinalIgnoreCase) ?? false)))
                .Take(30)
                .ToList();

            if (productoSeleccionadoId > 0 && filtrados.All(x => x.Id != productoSeleccionadoId))
            {
                var seleccionado = productos.FirstOrDefault(x => x.Id == productoSeleccionadoId);
                if (seleccionado is not null)
                {
                    filtrados.Insert(0, seleccionado);
                }
            }

            return filtrados;
        }
    }

    private IEnumerable<Cliente> ClientesFiltrados
    {
        get
        {
            var query = clientes.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(busquedaCliente))
            {
                query = query.Where(x =>
                    x.NombreRazonSocial.Contains(busquedaCliente, StringComparison.OrdinalIgnoreCase)
                    || x.DniCuit.Contains(busquedaCliente, StringComparison.OrdinalIgnoreCase)
                    || (x.Telefono?.Contains(busquedaCliente, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (x.Email?.Contains(busquedaCliente, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            var filtrados = query
                .OrderBy(x => x.NombreRazonSocial)
                .Take(50)
                .ToList();

            if (clienteIdSeleccionado > 0 && filtrados.All(x => x.Id != clienteIdSeleccionado))
            {
                var seleccionado = clientes.FirstOrDefault(x => x.Id == clienteIdSeleccionado);
                if (seleccionado is not null)
                {
                    filtrados.Insert(0, seleccionado);
                }
            }

            return filtrados;
        }
    }

    private decimal Subtotal => items.Sum(x => x.Subtotal);
    private decimal Total => Math.Max(0, Subtotal - form.DescuentoGeneral);
    private bool ClienteListo =>
        clienteIdSeleccionado > 0
        || (mostrarFormularioCliente && !string.IsNullOrWhiteSpace(clienteNuevo.Nombre));
    private bool TieneProductos => items.Count > 0 || productoSeleccionadoId > 0;
    private bool PuedeConfirmarVenta =>
        !procesando
        && TieneProductos
        && ClienteListo
        && vendedorIdSeleccionado > 0;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        clientes = await db.Clientes
            .AsNoTracking()
            .Include(x => x.CredencialCLU)
            .Where(x => x.Activo)
            .OrderBy(x => x.NombreRazonSocial)
            .ToListAsync();

        productos = await db.Productos
            .AsNoTracking()
            .Where(x => x.Activo)
            .OrderBy(x => x.Nombre)
            .ToListAsync();

        vendedores = (await UsuariosService.ListarVendedoresActivosAsync()).ToList();
        vendedorIdSeleccionado = AuthService.UsuarioActual?.Id ?? 0;

        cargando = false;
    }

    private void AbrirNuevoCliente()
    {
        mostrarFormularioCliente = true;
        clienteIdSeleccionado = 0;
        clienteSeleccionado = null;
        clienteNuevo = new();
        errores.Clear();
    }

    private void CerrarNuevoCliente()
    {
        mostrarFormularioCliente = false;
        clienteNuevo = new();
    }

    private Task ActualizarClienteSeleccionado()
    {
        if (clienteIdSeleccionado > 0)
        {
            mostrarFormularioCliente = false;
            clienteSeleccionado = clientes.SingleOrDefault(x => x.Id == clienteIdSeleccionado);
        }
        else
        {
            clienteSeleccionado = null;
        }

        return Task.CompletedTask;
    }

    private async Task GuardarNuevoClienteAsync()
    {
        errores.Clear();
        mensajeExito = null;

        if (!await CrearClienteDesdeFormularioAsync())
        {
            return;
        }

        mostrarFormularioCliente = false;
        clienteNuevo = new();
    }

    private async Task<bool> CrearClienteDesdeFormularioAsync()
    {
        var nombre = clienteNuevo.Nombre.Trim();
        var telefono = NormalizarTextoOpcional(clienteNuevo.Telefono);
        var email = NormalizarTextoOpcional(clienteNuevo.Email);
        var domicilio = NormalizarTextoOpcional(clienteNuevo.Domicilio);
        var dniCuit = clienteNuevo.DniCuit.Trim();

        if (string.IsNullOrWhiteSpace(nombre))
        {
            errores.Add("Debe indicar el nombre del cliente.");
            return false;
        }

        try
        {
            procesandoCliente = true;
            await using var db = await DbContextFactory.CreateDbContextAsync();

            Cliente cliente;
            if (!string.IsNullOrWhiteSpace(dniCuit))
            {
                var clienteExistente = await db.Clientes
                    .Include(x => x.CredencialCLU)
                    .SingleOrDefaultAsync(x => x.DniCuit == dniCuit);

                if (clienteExistente is not null)
                {
                    clienteExistente.NombreRazonSocial = nombre;
                    clienteExistente.Telefono = telefono ?? clienteExistente.Telefono;
                    clienteExistente.Email = email ?? clienteExistente.Email;
                    clienteExistente.Domicilio = domicilio ?? clienteExistente.Domicilio;
                    clienteExistente.Activo = true;
                    await db.SaveChangesAsync();
                    cliente = clienteExistente;
                }
                else
                {
                    cliente = CrearCliente(nombre, telefono, email, domicilio, dniCuit);
                    db.Clientes.Add(cliente);
                    await db.SaveChangesAsync();
                }
            }
            else
            {
                cliente = CrearCliente(nombre, telefono, email, domicilio, GenerarDniInterno());
                db.Clientes.Add(cliente);
                await db.SaveChangesAsync();
            }

            await RecargarClientesAsync(cliente.Id);
            return true;
        }
        catch (Exception ex)
        {
            errores.Add($"No se pudo guardar el cliente: {ex.Message}");
            return false;
        }
        finally
        {
            procesandoCliente = false;
        }
    }

    private async Task RecargarClientesAsync(int clienteSeleccionadoId)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        clientes = await db.Clientes
            .AsNoTracking()
            .Include(x => x.CredencialCLU)
            .Where(x => x.Activo)
            .OrderBy(x => x.NombreRazonSocial)
            .ToListAsync();

        clienteIdSeleccionado = clienteSeleccionadoId;
        clienteSeleccionado = clientes.SingleOrDefault(x => x.Id == clienteSeleccionadoId);
    }

    private Task ActualizarProductoSeleccionado()
    {
        productoSeleccionado = productos.SingleOrDefault(x => x.Id == productoSeleccionadoId);

        if (productoSeleccionado is null)
        {
            precioUnitario = 0;
            return Task.CompletedTask;
        }

        precioUnitario = productoSeleccionado.PrecioUnitario;
        cantidad = Math.Max(1, cantidad);
        return Task.CompletedTask;
    }

    private void AgregarItem()
    {
        errores.Clear();
        mensajeExito = null;

        if (productoSeleccionadoId <= 0)
        {
            errores.Add("Seleccione un producto para agregar.");
            return;
        }

        var producto = productos.FirstOrDefault(x => x.Id == productoSeleccionadoId);
        if (producto is null)
        {
            errores.Add("El producto seleccionado no está disponible.");
            return;
        }

        if (cantidad < 1)
        {
            errores.Add("La cantidad debe ser al menos 1.");
            return;
        }

        if (precioUnitario <= 0)
        {
            errores.Add("El precio debe ser mayor a cero.");
            return;
        }

        items.Add(new LineaVentaVm(producto, cantidad, precioUnitario, descuentoLinea));
        SincronizarRequest();

        productoSeleccionadoId = 0;
        productoSeleccionado = null;
        cantidad = 1;
        precioUnitario = 0;
        descuentoLinea = 0;
        busquedaProducto = string.Empty;
    }

    private bool AgregarProductoPendienteSiCorresponde()
    {
        if (productoSeleccionadoId <= 0)
        {
            return items.Count > 0;
        }

        var producto = productos.FirstOrDefault(x => x.Id == productoSeleccionadoId);
        if (producto is null)
        {
            errores.Add("El producto seleccionado no está disponible.");
            return false;
        }

        if (cantidad < 1)
        {
            errores.Add("La cantidad debe ser al menos 1.");
            return false;
        }

        if (precioUnitario <= 0)
        {
            errores.Add("El precio debe ser mayor a cero.");
            return false;
        }

        var yaEstaEnDetalle = items.Any(x =>
            x.Producto.Id == producto.Id
            && x.Cantidad == cantidad
            && x.PrecioUnitario == precioUnitario
            && x.Descuento == descuentoLinea);

        if (!yaEstaEnDetalle)
        {
            items.Add(new LineaVentaVm(producto, cantidad, precioUnitario, descuentoLinea));
        }

        productoSeleccionadoId = 0;
        productoSeleccionado = null;
        cantidad = 1;
        precioUnitario = 0;
        descuentoLinea = 0;
        busquedaProducto = string.Empty;
        return true;
    }

    private async Task RecargarProductosAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        productos = await db.Productos
            .AsNoTracking()
            .Where(x => x.Activo)
            .OrderBy(x => x.Nombre)
            .ToListAsync();
    }

    private async Task ReiniciarParaNuevaVentaAsync()
    {
        items.Clear();
        form.Items.Clear();
        form.DescuentoGeneral = 0;
        form.Observaciones = null;
        clienteIdSeleccionado = 0;
        clienteSeleccionado = null;
        busquedaCliente = string.Empty;
        busquedaProducto = string.Empty;
        productoSeleccionadoId = 0;
        productoSeleccionado = null;
        cantidad = 1;
        precioUnitario = 0;
        descuentoLinea = 0;
        mostrarFormularioCliente = false;
        clienteNuevo = new();
        vendedorIdSeleccionado = AuthService.UsuarioActual?.Id ?? 0;
        await RecargarProductosAsync();
        await Js.InvokeVoidAsync("stockSanti.scrollToElement", "venta-rapida");
    }

    private void QuitarItem(LineaVentaVm item)
    {
        items.Remove(item);
        SincronizarRequest();
    }

    private async Task ConfirmarVentaAsync()
    {
        errores.Clear();
        mensajeExito = null;

        if (clienteIdSeleccionado <= 0 && mostrarFormularioCliente)
        {
            if (!await CrearClienteDesdeFormularioAsync())
            {
                return;
            }
        }

        if (!AgregarProductoPendienteSiCorresponde())
        {
            return;
        }

        SincronizarRequest();

        if (form.ClienteId is null or <= 0)
        {
            errores.Add("Debe seleccionar un cliente o crear uno nuevo.");
            return;
        }

        if (form.VendedorId is null or <= 0)
        {
            errores.Add("Debe seleccionar el vendedor.");
            return;
        }

        if (form.Items.Count == 0)
        {
            errores.Add("Debe agregar al menos un producto.");
            return;
        }

        try
        {
            procesando = true;
            var ventaGuardada = await VentasService.ConfirmarVentaAsync(form);

            mensajeExito = $"Venta {ventaGuardada.NumeroComprobante} registrada — {MonedaHelper.FormatearUsd(ventaGuardada.Total)}.";

            await ReiniciarParaNuevaVentaAsync();
        }
        catch (VentaValidationException ex)
        {
            errores.AddRange(ex.Errores);
        }
        catch (Exception ex)
        {
            errores.Add($"Error inesperado al confirmar la venta: {ex.Message}");
        }
        finally
        {
            procesando = false;
        }
    }

    private void SincronizarRequest()
    {
        form.ClienteId = clienteIdSeleccionado > 0 ? clienteIdSeleccionado : null;
        form.VendedorId = vendedorIdSeleccionado > 0 ? vendedorIdSeleccionado : null;
        form.Observaciones = string.IsNullOrWhiteSpace(form.Observaciones) ? null : form.Observaciones.Trim();
        form.Items = items.Select(x => new ItemVentaRequest
        {
            ProductoId = x.Producto.Id,
            Cantidad = x.Cantidad,
            PrecioUnitario = x.PrecioUnitario,
            Descuento = x.Descuento
        }).ToList();
    }

    private static Cliente CrearCliente(
        string nombre,
        string? telefono,
        string? email,
        string? domicilio,
        string dniCuit) => new()
    {
        NombreRazonSocial = nombre,
        DniCuit = dniCuit,
        Telefono = telefono,
        Email = email,
        Domicilio = domicilio,
        Activo = true
    };

    private static string? NormalizarTextoOpcional(string? valor)
    {
        var normalizado = valor?.Trim();
        return string.IsNullOrWhiteSpace(normalizado) ? null : normalizado;
    }

    private static string GenerarDniInterno() =>
        $"S{DateTime.UtcNow:yyMMddHHmmss}{Random.Shared.Next(1000, 9999)}";

    private static string FormatearCliente(Cliente cliente)
    {
        var datos = new List<string>();
        if (!ClienteHelper.EsDniInterno(cliente.DniCuit))
        {
            datos.Add(cliente.DniCuit);
        }

        if (!string.IsNullOrWhiteSpace(cliente.Telefono))
        {
            datos.Add($"Cel. {cliente.Telefono}");
        }

        return datos.Count == 0
            ? cliente.NombreRazonSocial
            : $"{cliente.NombreRazonSocial} - {string.Join(" - ", datos)}";
    }

    private sealed class ClienteNuevoForm
    {
        public string Nombre { get; set; } = string.Empty;
        public string DniCuit { get; set; } = string.Empty;
        public string Telefono { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Domicilio { get; set; } = string.Empty;
    }

    private sealed record LineaVentaVm(
        Producto Producto,
        int Cantidad,
        decimal PrecioUnitario,
        decimal Descuento)
    {
        public decimal Subtotal => Math.Max(0, (PrecioUnitario * Cantidad) - Descuento);
        public decimal TotalEstimado => Subtotal;
    }
}
