@page "/ventas/{VentaId:int}/imprimir"
@layout EmptyLayout
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IJSRuntime Js

<HeadContent>
    <link rel="stylesheet" href="css/app.css" />
</HeadContent>

<AuthorizeAccess Modulo="ModuloSistema.Ventas">
<PageTitle>Comprobante de venta - StockSantiCAZA</PageTitle>

@if (venta is null)
{
    <div class="panel">
        <p>Cargando comprobante...</p>
    </div>
}
else
{
    <div class="panel no-print" style="margin: 1rem;">
        <div class="actions">
            <button class="button primary" @onclick="ImprimirAsync">Imprimir</button>
            <button class="button ghost" @onclick="CerrarAsync">Cerrar</button>
        </div>
    </div>

    <article class="ticket print-area" style="margin: 1rem auto;">
        <header>
            <strong>StockSantiCAZA</strong>
            <small>Comprobante de venta</small>
            <small>Nº @venta.NumeroComprobante</small>
            <small>@venta.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
        </header>

        <section class="sale-detail">
            <p><strong>Cliente:</strong> @venta.Cliente.NombreRazonSocial</p>
            <p><strong>Documento:</strong> @ClienteHelper.FormatearDocumentoCliente(venta.Cliente)</p>
            @if (!string.IsNullOrWhiteSpace(venta.Cliente.Telefono))
            {
                <p><strong>Teléfono:</strong> @venta.Cliente.Telefono</p>
            }
            @if (!string.IsNullOrWhiteSpace(venta.Cliente.Domicilio))
            {
                <p><strong>Domicilio:</strong> @venta.Cliente.Domicilio</p>
            }
            <p><strong>Vendedor:</strong> @(string.IsNullOrWhiteSpace(venta.Vendedor) ? "—" : venta.Vendedor)</p>

            <table>
                <thead>
                    <tr>
                        <th>Cant.</th>
                        <th>Producto</th>
                        <th>Total USD</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in venta.Detalles)
                    {
                        <tr>
                            <td>@detalle.Cantidad</td>
                            <td>
                                @detalle.Producto.Nombre
                                @if (detalle.Arma is not null)
                                {
                                    <small>Serie @detalle.Arma.NumeroSerie</small>
                                }
                                @if (detalle.MunicionLote is not null)
                                {
                                    <small>Lote @detalle.MunicionLote.NumeroLote</small>
                                }
                            </td>
                            <td>@MonedaHelper.FormatearUsd(detalle.Total)</td>
                        </tr>
                    }
                </tbody>
            </table>

            <p>Subtotal: @MonedaHelper.FormatearUsd(venta.Subtotal)</p>
            @if (venta.DescuentoTotal > 0)
            {
                <p>Descuento: -@MonedaHelper.FormatearUsd(venta.DescuentoTotal)</p>
            }
            <p><strong>TOTAL USD: @MonedaHelper.FormatearUsd(venta.Total)</strong></p>
        </section>

        <footer>
            @if (!string.IsNullOrWhiteSpace(venta.Observaciones))
            {
                <small>Obs.: @venta.Observaciones</small>
            }
            <small>Documento interno de registro de venta.</small>
        </footer>
    </article>
}

</AuthorizeAccess>

@code {
    [Parameter]
    public int VentaId { get; set; }

    private Venta? venta;

    protected override async Task OnParametersSetAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        venta = await db.Ventas.AsNoTracking()
            .Include(x => x.Cliente)
            .Include(x => x.Detalles)
                .ThenInclude(x => x.Producto)
            .Include(x => x.Detalles)
                .ThenInclude(x => x.Arma)
            .Include(x => x.Detalles)
                .ThenInclude(x => x.MunicionLote)
            .SingleOrDefaultAsync(x => x.Id == VentaId);
    }

    private async Task ImprimirAsync() => await Js.InvokeVoidAsync("stockSanti.printPage");

    private async Task CerrarAsync() => await Js.InvokeVoidAsync("window.close");
}
