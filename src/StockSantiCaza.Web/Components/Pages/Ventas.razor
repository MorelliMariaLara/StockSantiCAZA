@page "/ventas"
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IAuthService AuthService
@inject IVentasService VentasService
@inject ConfirmDialogService ConfirmService
@inject AlertDialogService AlertService

<AuthorizeAccess Modulo="ModuloSistema.Ventas">
<PageTitle>Ventas - StockSantiCAZA</PageTitle>

<div class="section-header">
    <div>
        <h1>Ventas</h1>
        <p>@(EsAdministrador ? "Consulte ventas, totales y trazabilidad." : "Consulte el registro de ventas y trazabilidad.")</p>
    </div>
    <a class="button primary" href="ventas/nueva">Nueva venta</a>
</div>

<section class="panel">
    <div class="grid sales-filters">
        @if (EsAdministrador)
        {
            <label>
                Desde
                <InputDate class="input" @bind-Value="fechaDesde" />
            </label>

            <label>
                Hasta
                <InputDate class="input" @bind-Value="fechaHasta" />
            </label>
        }

        <label>
            Buscar
            <InputText class="input" @bind-Value="busqueda" placeholder="Cliente, vendedor, número, producto, serie o lote..." />
        </label>

        @if (EsAdministrador)
        {
            <label>
                Estado
                <InputSelect class="input" @bind-Value="estadoFiltro">
                    <option value="">Todos</option>
                    @foreach (var estado in Enum.GetValues<EstadoVenta>())
                    {
                        <option value="@estado">@estado</option>
                    }
                </InputSelect>
            </label>
        }

        <button class="button" @onclick="CargarVentasAsync" disabled="@cargando">
            @(cargando ? "Cargando..." : "Actualizar")
        </button>
    </div>

    @if (!EsAdministrador)
    {
        <p class="hint">Mostrando sus ventas recientes. Los totales y filtros por fecha son solo para administradores.</p>
    }
</section>

@if (cargando && ventas.Count == 0)
{
    <p>Cargando ventas...</p>
}
else
{
    @if (EsAdministrador)
    {
        <section class="grid cards">
            <div class="card">
                <span class="metric-label">Ventas filtradas</span>
                <strong>@VentasFiltradas.Count()</strong>
            </div>
            <div class="card">
                <span class="metric-label">Total vendido</span>
                <strong>@MonedaHelper.FormatearUsd(VentasFiltradas.Where(x => x.Estado != EstadoVenta.Anulada).Sum(x => x.Total))</strong>
            </div>
            <div class="card">
                <span class="metric-label">Productos vendidos</span>
                <strong>@VentasFiltradas.SelectMany(x => x.Detalles).Sum(x => x.Cantidad)</strong>
            </div>
            <div class="card warning-card">
                <span class="metric-label">Con trazabilidad</span>
                <strong>@VentasFiltradas.SelectMany(x => x.Detalles).Count(x => x.Arma is not null || x.MunicionLote is not null)</strong>
            </div>
        </section>

        <section class="panel">
            <div class="section-header">
                <div>
                    <h2>Totales por vendedor</h2>
                    <p>Resumen del período y filtros aplicados (ventas no anuladas).</p>
                </div>
            </div>

            @if (!ResumenPorVendedor.Any())
            {
                <p>No hay ventas para mostrar en el resumen por vendedor.</p>
            }
            else
            {
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Vendedor</th>
                                <th>Cantidad de ventas</th>
                                <th>Total vendido USD</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ResumenPorVendedor)
                            {
                                <tr>
                                    <td><strong>@item.Vendedor</strong></td>
                                    <td>@item.CantidadVentas</td>
                                    <td>@MonedaHelper.FormatearUsd(item.TotalVendido)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th>Total general</th>
                                <th>@ResumenPorVendedor.Sum(x => x.CantidadVentas)</th>
                                <th>@MonedaHelper.FormatearUsd(ResumenPorVendedor.Sum(x => x.TotalVendido))</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </section>
    }

    <section class="panel">
        <div class="section-header">
            <div>
                <h2>Registro de ventas</h2>
                <p>Cliente, vendedor y detalle por serie o lote.</p>
            </div>
        </div>

        @if (!VentasFiltradas.Any())
        {
            <p>No hay ventas para mostrar.</p>
        }
        else
        {
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Nº venta</th>
                            <th>Cliente</th>
                            <th>Vendedor</th>
                            <th>Estado</th>
                            @if (EsAdministrador)
                            {
                                <th>Total</th>
                            }
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var venta in VentasFiltradas)
                        {
                            <tr>
                                <td>@venta.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <strong>@(venta.NumeroComprobante ?? $"VTA-{venta.Id:D8}")</strong>
                                </td>
                                <td>
                                    @DisplayHelper.Mostrar(venta.Cliente.NombreRazonSocial)
                                    <small>@DisplayHelper.Mostrar(venta.Cliente.DniCuit)</small>
                                </td>
                                <td>@FormatearVendedor(venta)</td>
                                <td><span class="@ObtenerClaseEstado(venta.Estado)">@venta.Estado</span></td>
                                @if (EsAdministrador)
                                {
                                    <td>@MonedaHelper.FormatearUsd(venta.Total)</td>
                                }
                                <td>
                                    @if (PuedeEliminarVenta(venta))
                                    {
                                        <button type="button" class="button btn-delete" @onclick="() => BorrarVentaAsync(venta)">Borrar</button>
                                    }
                                </td>
                            </tr>
                            <tr class="sale-detail-row">
                                <td colspan="@(EsAdministrador ? 7 : 6)">
                                    <div class="sale-detail">
                                        @if (!string.IsNullOrWhiteSpace(venta.Observaciones))
                                        {
                                            <p><strong>Observaciones:</strong> @venta.Observaciones</p>
                                        }

                                        <table>
                                            <thead>
                                                <tr>
                                                    <th>Producto</th>
                                                    <th>Categoría</th>
                                                    <th>Trazabilidad</th>
                                                    <th>Cant.</th>
                                                    @if (EsAdministrador)
                                                    {
                                                        <th>Precio USD</th>
                                                        <th>Total USD</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var detalle in venta.Detalles.OrderBy(x => x.Producto.Nombre))
                                                {
                                                    <tr>
                                                        <td>
                                                            <strong>@detalle.Producto.Nombre</strong>
                                                            <small>@detalle.Producto.Sku</small>
                                                        </td>
                                                        <td>@DisplayHelper.Mostrar(detalle.Producto.Categoria)</td>
                                                        <td>@ObtenerTrazabilidad(detalle)</td>
                                                        <td>@detalle.Cantidad</td>
                                                        @if (EsAdministrador)
                                                        {
                                                            <td>@MonedaHelper.FormatearUsd(detalle.PrecioUnitario)</td>
                                                            <td>@MonedaHelper.FormatearUsd(detalle.Total)</td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}

</AuthorizeAccess>

@code {
    private List<Venta> ventas = [];
    private DateTime fechaDesde = DateTime.Today.AddDays(-30);
    private DateTime fechaHasta = DateTime.Today;
    private string busqueda = string.Empty;
    private string estadoFiltro = string.Empty;
    private bool cargando = true;

    private bool EsAdministrador => AuthService.UsuarioActual?.EsAdministrador == true;

    private IEnumerable<Venta> VentasFiltradas
    {
        get
        {
            var query = ventas.AsEnumerable();

            if (!EsAdministrador && AuthService.UsuarioActual is not null)
            {
                query = query.Where(x => x.VendedorId == AuthService.UsuarioActual.Id);
            }

            if (EsAdministrador && Enum.TryParse<EstadoVenta>(estadoFiltro, out var estado))
            {
                query = query.Where(x => x.Estado == estado);
            }

            if (!string.IsNullOrWhiteSpace(busqueda))
            {
                query = query.Where(CoincideBusqueda);
            }

            return query.OrderByDescending(x => x.Fecha);
        }
    }

    private IEnumerable<ResumenVendedorVm> ResumenPorVendedor =>
        VentasFiltradas
            .Where(x => x.Estado != EstadoVenta.Anulada)
            .GroupBy(x => new
            {
                x.VendedorId,
                Nombre = FormatearVendedor(x)
            })
            .Select(g => new ResumenVendedorVm(
                g.Key.Nombre,
                g.Count(),
                g.Sum(x => x.Total)))
            .OrderByDescending(x => x.TotalVendido)
            .ThenBy(x => x.Vendedor);

    protected override async Task OnInitializedAsync()
    {
        await CargarVentasAsync();
    }

    private async Task CargarVentasAsync()
    {
        if (EsAdministrador && fechaDesde.Date > fechaHasta.Date)
        {
            await AlertService.ShowErrorAsync("La fecha desde no puede ser posterior a la fecha hasta.");
            return;
        }

        try
        {
            cargando = true;
            await using var db = await DbContextFactory.CreateDbContextAsync();

            var query = db.Ventas
                .AsNoTracking()
                .Include(x => x.Cliente)
                .Include(x => x.Detalles)
                    .ThenInclude(x => x.Producto)
                .Include(x => x.Detalles)
                    .ThenInclude(x => x.Arma)
                .Include(x => x.Detalles)
                    .ThenInclude(x => x.MunicionLote)
                .AsQueryable();

            if (EsAdministrador)
            {
                var desde = fechaDesde.Date;
                var hasta = fechaHasta.Date.AddDays(1).AddTicks(-1);
                query = query.Where(x => x.Fecha >= desde && x.Fecha <= hasta);
            }
            else if (AuthService.UsuarioActual is not null)
            {
                var usuarioId = AuthService.UsuarioActual.Id;
                query = query
                    .Where(x => x.VendedorId == usuarioId)
                    .OrderByDescending(x => x.Fecha)
                    .Take(100);
            }

            ventas = await query
                .OrderByDescending(x => x.Fecha)
                .Take(500)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync($"No se pudieron cargar las ventas: {ex.Message}");
        }
        finally
        {
            cargando = false;
        }
    }

    private bool CoincideBusqueda(Venta venta)
    {
        return (venta.NumeroComprobante?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
            || venta.Cliente.NombreRazonSocial.Contains(busqueda, StringComparison.OrdinalIgnoreCase)
            || venta.Cliente.DniCuit.Contains(busqueda, StringComparison.OrdinalIgnoreCase)
            || FormatearVendedor(venta).Contains(busqueda, StringComparison.OrdinalIgnoreCase)
            || venta.Detalles.Any(detalle =>
                detalle.Producto.Sku.Contains(busqueda, StringComparison.OrdinalIgnoreCase)
                || detalle.Producto.Nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase)
                || (detalle.Arma?.NumeroSerie.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
                || (detalle.MunicionLote?.NumeroLote.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private static string ObtenerTrazabilidad(DetalleVenta detalle)
    {
        if (detalle.Arma is not null)
        {
            return $"Serie {detalle.Arma.NumeroSerie} - {detalle.Arma.Marca} {detalle.Arma.Modelo} - Calibre {detalle.Arma.Calibre}";
        }

        if (detalle.MunicionLote is not null)
        {
            return $"Lote {detalle.MunicionLote.NumeroLote} - Calibre {detalle.MunicionLote.Calibre}";
        }

        return "No aplica";
    }

    private static string FormatearVendedor(Venta venta) =>
        string.IsNullOrWhiteSpace(venta.Vendedor) ? "Sin vendedor asignado" : venta.Vendedor;

    private static string ObtenerClaseEstado(EstadoVenta estado) => estado switch
    {
        EstadoVenta.Anulada => "badge danger",
        EstadoVenta.Borrador => "badge muted",
        EstadoVenta.Confirmada => "badge ok",
        EstadoVenta.Facturada => "badge ok",
        _ => "badge muted"
    };

    private bool PuedeEliminarVenta(Venta venta) =>
        EsAdministrador || venta.VendedorId == AuthService.UsuarioActual?.Id;

    private async Task BorrarVentaAsync(Venta venta)
    {
        var referencia = venta.NumeroComprobante ?? $"VTA-{venta.Id:D8}";
        var confirmado = await ConfirmService.AskAsync(
            $"¿Eliminar la venta {referencia} de {DisplayHelper.Mostrar(venta.Cliente.NombreRazonSocial)}? Se revertirá el stock asociado.",
            confirmText: "Eliminar");

        if (!confirmado)
        {
            return;
        }

        try
        {
            await VentasService.EliminarAsync(
                venta.Id,
                AuthService.UsuarioActual?.Id,
                EsAdministrador);
            await AlertService.ShowSuccessAsync($"Venta {referencia} eliminada correctamente.");
            await CargarVentasAsync();
        }
        catch (VentaValidationException ex)
        {
            await AlertService.ShowErrorsAsync(ex.Errores);
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync($"No se pudo eliminar la venta: {ex.Message}");
        }
    }

    private sealed record ResumenVendedorVm(string Vendedor, int CantidadVentas, decimal TotalVendido);
}
