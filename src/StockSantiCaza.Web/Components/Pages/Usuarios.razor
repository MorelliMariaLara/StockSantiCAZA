@page "/usuarios"
@inject IUsuariosService UsuariosService
@inject IAuthService AuthService
@inject IJSRuntime Js
@inject ConfirmDialogService ConfirmService
@inject AlertDialogService AlertService

<AuthorizeAccess RequiereAdministrador="true">
    <PageTitle>Usuarios - StockSantiCAZA</PageTitle>

    <h1>Usuarios y vendedores</h1>

    @if (!string.IsNullOrWhiteSpace(mensaje))
    {
        <div class="alert alert-success">@mensaje</div>
    }

    @if (errores.Count > 0)
    {
        <div class="alert alert-danger">
            <ul>
                @foreach (var error in errores)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <section class="panel @(form.Id is not null ? "panel-editing" : null)" id="edit-form">
        <h2>
            @if (form.Id is null)
            {
                <span class="step-badge">+</span>
                <span>Nuevo usuario</span>
            }
            else
            {
                <span class="step-badge edit">✎</span>
                <span>Editar usuario #@form.Id</span>
            }
        </h2>
        <EditForm Model="form" OnSubmit="GuardarAsync" @key="EditFormKey">
            <div class="grid client-form">
                <label>
                    Nombre
                    <InputText class="input" @bind-Value="form.Nombre" />
                </label>
                <label>
                    Usuario de acceso
                    <InputText class="input" @bind-Value="form.Login" />
                </label>
                <label>
                    Contraseña @(form.Id is null ? string.Empty : "(opcional)")
                    <InputText class="input" type="password" @bind-Value="form.Password" />
                </label>
                <label>
                    Rol
                    <InputSelect class="input" @bind-Value="form.Rol">
                        @foreach (var rol in Enum.GetValues<RolUsuario>())
                        {
                            <option value="@rol">@rol</option>
                        }
                    </InputSelect>
                </label>
            </div>
            <div class="actions">
                <button type="submit" class="button primary" disabled="@guardando">@(guardando ? "Guardando..." : "Guardar usuario")</button>
                <button type="button" class="button ghost" @onclick="NuevoUsuario">Limpiar</button>
            </div>
        </EditForm>
    </section>

    <section class="panel">
        <h2>Perfiles registrados</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Login</th>
                        <th>Rol</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in usuarios)
                    {
                        <tr>
                            <td>@usuario.Nombre</td>
                            <td>@usuario.Login</td>
                            <td>@usuario.Rol</td>
                            <td>
                                <div class="row-actions">
                                    <button type="button" class="button btn-edit" @onclick="() => EditarAsync(usuario)">Editar</button>
                                    <button type="button" class="button btn-delete" @onclick="() => BorrarAsync(usuario)">Borrar</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</AuthorizeAccess>

@code {
    private readonly List<string> errores = [];
    private List<Usuario> usuarios = [];
    private UsuarioForm form = new();
    private bool guardando;
    private string? mensaje;
    private int EditFormKey => form.Id ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await RecargarAsync();
    }

    private async Task GuardarAsync()
    {
        errores.Clear();
        mensaje = null;
        guardando = true;

        try
        {
            var esNuevo = form.Id is null;
            var idGuardado = form.Id;

            await UsuariosService.GuardarAsync(new UsuarioFormRequest
            {
                Id = form.Id,
                Nombre = form.Nombre,
                Login = form.Login,
                Password = form.Password,
                Rol = form.Rol
            });

            mensaje = esNuevo ? "Usuario creado correctamente." : "Usuario actualizado correctamente.";
            await RecargarAsync();

            if (esNuevo)
            {
                NuevoUsuario();
            }
            else if (idGuardado is int id)
            {
                var editado = usuarios.SingleOrDefault(x => x.Id == id);
                if (editado is not null)
                {
                    Editar(editado);
                }
            }
        }
        catch (Exception ex)
        {
            errores.Add(ex.Message);
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task BorrarAsync(Usuario usuario)
    {
        errores.Clear();
        mensaje = null;

        var confirmado = await ConfirmService.AskAsync(
            $"¿Eliminar al usuario {usuario.Nombre} ({usuario.Login})? Esta acción no se puede deshacer.");

        if (!confirmado)
        {
            return;
        }

        try
        {
            await UsuariosService.EliminarAsync(usuario.Id, AuthService.UsuarioActual?.Id);
            mensaje = "Usuario eliminado correctamente.";

            if (form.Id == usuario.Id)
            {
                NuevoUsuario();
            }

            await RecargarAsync();
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync(ex.Message);
        }
    }

    private async Task RecargarAsync()
    {
        usuarios = (await UsuariosService.ListarAsync()).ToList();
    }

    private void NuevoUsuario()
    {
        form = new UsuarioForm();
        errores.Clear();
        mensaje = null;
    }

    private async Task EditarAsync(Usuario usuario)
    {
        errores.Clear();
        mensaje = null;
        Editar(usuario);
        await Js.InvokeVoidAsync("stockSanti.scrollToElement", "edit-form");
    }

    private void Editar(Usuario usuario)
    {
        form = new UsuarioForm
        {
            Id = usuario.Id,
            Nombre = usuario.Nombre,
            Login = usuario.Login,
            Rol = usuario.Rol,
            Password = string.Empty
        };
    }

    private sealed class UsuarioForm
    {
        public int? Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string Login { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public RolUsuario Rol { get; set; } = RolUsuario.Vendedor;
    }
}
