@page "/clientes"
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject IJSRuntime Js
@inject ConfirmDialogService ConfirmService
@inject AlertDialogService AlertService

<AuthorizeAccess Modulo="ModuloSistema.Clientes">
<PageTitle>Clientes - StockSantiCAZA</PageTitle>

<h1>Clientes</h1>

@if (cargando)
{
    <p>Cargando clientes...</p>
}
else
{
    @if (errores.Count > 0)
    {
        <div class="alert alert-danger">
            <strong>No se pudo guardar el cliente</strong>
            <ul>
                @foreach (var error in errores)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(mensaje))
    {
        <div class="alert alert-success">@mensaje</div>
    }

    <section class="grid cards">
        <div class="card">
            <span class="metric-label">Total clientes</span>
            <strong>@clientes.Count</strong>
        </div>
        <div class="card">
            <span class="metric-label">Con CLU cargada</span>
            <strong>@clientes.Count(x => x.CredencialCLU is not null)</strong>
        </div>
        <div class="card warning-card">
            <span class="metric-label">CLU vencidas</span>
            <strong>@clientes.Count(x => x.CredencialCLU is not null && !x.CredencialCLU.EstaVigente)</strong>
        </div>
    </section>

    <section class="panel @(form.Id is not null ? "panel-editing" : null)" id="edit-form">
        <div class="section-header">
            <div>
                <h2>
                    @if (form.Id is null)
                    {
                        <span class="step-badge">+</span>
                        <span>Agregar cliente</span>
                    }
                    else
                    {
                        <span class="step-badge edit">✎</span>
                        <span>Editar cliente #@form.Id</span>
                    }
                </h2>
                <p>Administre datos de contacto, estado y credencial CLU para luego vincularlos a ventas.</p>
            </div>
            @if (form.Id is not null)
            {
                <button type="button" class="button ghost" @onclick="NuevoCliente">Nuevo cliente</button>
            }
        </div>

        <EditForm Model="form" OnSubmit="GuardarClienteAsync" @key="EditFormKey">

            <div class="grid client-form">
                <label>
                    Nombre / razón social
                    <InputText class="input" @bind-Value="form.NombreRazonSocial" />
                </label>

                <label>
                    DNI/CUIT
                    <InputText class="input" @bind-Value="form.DniCuit" />
                </label>

                <label>
                    Email
                    <InputText class="input" @bind-Value="form.Email" />
                </label>

                <label>
                    Teléfono / celular
                    <InputText class="input" @bind-Value="form.Telefono" />
                </label>

                <label>
                    Domicilio
                    <InputText class="input" @bind-Value="form.Domicilio" />
                </label>
            </div>

            <section class="subpanel">
                <label class="checkbox-label">
                    <InputCheckbox @bind-Value="form.TieneClu" />
                    Cargar credencial CLU
                </label>

                @if (form.TieneClu)
                {
                    <div class="grid clu-form">
                        <label>
                            Número de legajo
                            <InputText class="input" @bind-Value="form.NumeroLegajoClu" />
                        </label>

                        <label>
                            Fecha de emisión
                            <InputDate class="input" @bind-Value="form.FechaEmisionClu" />
                        </label>

                        <label>
                            Fecha de vencimiento
                            <InputDate class="input" @bind-Value="form.FechaVencimientoClu" />
                        </label>
                    </div>
                }
            </section>

            <div class="actions">
                <button type="submit" class="button primary" disabled="@guardando">
                    @(guardando ? "Guardando..." : "Guardar cliente")
                </button>
                <button type="button" class="button ghost" @onclick="NuevoCliente">Limpiar</button>
            </div>
        </EditForm>
    </section>

    <section class="panel">
        <div class="section-header">
            <div>
                <h2>Listado de clientes</h2>
                <p>Busque clientes y consulte ventas vinculadas.</p>
            </div>
        </div>

        <div class="grid client-filters">
            <label>
                Buscar
                <InputText class="input" @bind-Value="busqueda" placeholder="Nombre, DNI/CUIT, email, teléfono..." />
            </label>
        </div>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Contacto</th>
                        <th>CLU</th>
                        <th>Vinculaciones</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cliente in ClientesFiltrados)
                    {
                        <tr>
                            <td>
                                <strong>@DisplayHelper.Mostrar(cliente.NombreRazonSocial)</strong>
                                <small>@DisplayHelper.Mostrar(cliente.DniCuit)</small>
                            </td>
                            <td>@FormatearContacto(cliente)</td>
                            <td>@FormatearClu(cliente.CredencialCLU)</td>
                            <td>
                                <span>@cliente.Ventas.Count venta(s)</span>
                                <small>@cliente.ArmasRegistradas.Count arma(s) registradas</small>
                            </td>
                            <td>
                                <div class="row-actions">
                                    <button type="button" class="button btn-edit" @onclick="() => EditarClienteAsync(cliente)">Editar</button>
                                    <button type="button" class="button btn-delete" @onclick="() => BorrarClienteAsync(cliente)">Borrar</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

</AuthorizeAccess>

@code {
    private readonly List<string> errores = new();
    private List<Cliente> clientes = new();
    private ClienteForm form = new();
    private bool cargando = true;
    private bool guardando;
    private string? mensaje;
    private string busqueda = string.Empty;
    private int EditFormKey => form.Id ?? 0;

    private IEnumerable<Cliente> ClientesFiltrados
    {
        get
        {
            var query = clientes.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(busqueda))
            {
                query = query.Where(x =>
                    (x.NombreRazonSocial?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (x.DniCuit?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (x.Email?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (x.Telefono?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (x.Domicilio?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            return query.OrderBy(x => x.NombreRazonSocial ?? string.Empty);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await RecargarClientesAsync();
        cargando = false;
    }

    private async Task GuardarClienteAsync()
    {
        errores.Clear();
        mensaje = null;

        var nombre = DisplayHelper.NormalizarTexto(form.NombreRazonSocial);
        var dniCuit = DisplayHelper.NormalizarOpcional(form.DniCuit);
        var numeroLegajo = DisplayHelper.NormalizarOpcional(form.NumeroLegajoClu);

        try
        {
            guardando = true;
            await using var db = await DbContextFactory.CreateDbContextAsync();

            var clienteActualId = form.Id;
            if (!string.IsNullOrWhiteSpace(dniCuit))
            {
                var dniDuplicado = await db.Clientes.AnyAsync(x =>
                    x.DniCuit == dniCuit
                    && (!clienteActualId.HasValue || x.Id != clienteActualId.Value));

                if (dniDuplicado)
                {
                    errores.Add($"Ya existe un cliente con DNI/CUIT {dniCuit}.");
                    return;
                }
            }

            if (form.TieneClu && !string.IsNullOrWhiteSpace(numeroLegajo))
            {
                var cluDuplicada = await db.CredencialesCLU.AnyAsync(x =>
                    x.NumeroLegajo == numeroLegajo
                    && (!clienteActualId.HasValue || x.ClienteId != clienteActualId.Value));

                if (cluDuplicada)
                {
                    errores.Add($"Ya existe una CLU con legajo {numeroLegajo}.");
                    return;
                }
            }

            Cliente cliente;
            var esNuevo = form.Id is null;

            if (esNuevo)
            {
                cliente = new Cliente();
                db.Clientes.Add(cliente);
            }
            else
            {
                var clienteId = form.Id.GetValueOrDefault();
                var clienteExistente = await db.Clientes
                    .Include(x => x.CredencialCLU)
                    .SingleOrDefaultAsync(x => x.Id == clienteId);

                if (clienteExistente is null)
                {
                    errores.Add("El cliente seleccionado ya no existe.");
                    return;
                }

                cliente = clienteExistente;
            }

            cliente.NombreRazonSocial = nombre;
            cliente.DniCuit = dniCuit;
            cliente.Email = DisplayHelper.NormalizarOpcional(form.Email);
            cliente.Telefono = DisplayHelper.NormalizarOpcional(form.Telefono);
            cliente.Domicilio = DisplayHelper.NormalizarOpcional(form.Domicilio);
            cliente.Activo = true;

            if (form.TieneClu && !string.IsNullOrWhiteSpace(numeroLegajo))
            {
                cliente.CredencialCLU ??= new CredencialCLU();
                cliente.CredencialCLU.NumeroLegajo = numeroLegajo;
                cliente.CredencialCLU.FechaEmision = form.FechaEmisionClu;
                cliente.CredencialCLU.FechaVencimiento = form.FechaVencimientoClu;
            }
            else if (cliente.CredencialCLU is not null)
            {
                db.CredencialesCLU.Remove(cliente.CredencialCLU);
                cliente.CredencialCLU = null;
            }

            await db.SaveChangesAsync();
            mensaje = esNuevo ? "Cliente agregado correctamente." : "Cliente actualizado correctamente.";
            await RecargarClientesAsync();
            EditarCliente(clientes.Single(x => x.Id == cliente.Id));
        }
        catch (Exception ex)
        {
            errores.Add($"Error inesperado al guardar cliente: {ex.Message}");
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task BorrarClienteAsync(Cliente cliente)
    {
        errores.Clear();
        mensaje = null;

        var confirmado = await ConfirmService.AskAsync(
            $"¿Eliminar al cliente {DisplayHelper.Mostrar(cliente.NombreRazonSocial)}? Esta acción no se puede deshacer.");

        if (!confirmado)
        {
            return;
        }

        try
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();

            var tieneVentas = await db.Ventas.AnyAsync(x => x.ClienteId == cliente.Id);
            if (tieneVentas)
            {
                await AlertService.ShowErrorAsync("No se puede eliminar el cliente porque tiene ventas registradas.");
                return;
            }

            var clienteExistente = await db.Clientes
                .Include(x => x.CredencialCLU)
                .SingleOrDefaultAsync(x => x.Id == cliente.Id);

            if (clienteExistente is null)
            {
                await AlertService.ShowErrorAsync("El cliente seleccionado ya no existe.");
                return;
            }

            db.Clientes.Remove(clienteExistente);
            await db.SaveChangesAsync();
            mensaje = "Cliente eliminado correctamente.";

            if (form.Id == cliente.Id)
            {
                NuevoCliente();
            }

            await RecargarClientesAsync();
        }
        catch (Exception ex)
        {
            await AlertService.ShowErrorAsync($"No se pudo eliminar el cliente: {ex.Message}");
        }
    }

    private async Task RecargarClientesAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        clientes = await db.Clientes
            .AsNoTracking()
            .Include(x => x.CredencialCLU)
            .Include(x => x.Ventas)
            .Include(x => x.ArmasRegistradas)
            .OrderBy(x => x.NombreRazonSocial)
            .ToListAsync();
    }

    private void NuevoCliente()
    {
        form = new ClienteForm();
        errores.Clear();
        mensaje = null;
    }

    private async Task EditarClienteAsync(Cliente cliente)
    {
        errores.Clear();
        mensaje = null;
        EditarCliente(cliente);
        await Js.InvokeVoidAsync("stockSanti.scrollToElement", "edit-form");
    }

    private void EditarCliente(Cliente cliente)
    {
        form = new ClienteForm
        {
            Id = cliente.Id,
            NombreRazonSocial = cliente.NombreRazonSocial ?? string.Empty,
            DniCuit = cliente.DniCuit ?? string.Empty,
            Email = cliente.Email ?? string.Empty,
            Telefono = cliente.Telefono ?? string.Empty,
            Domicilio = cliente.Domicilio ?? string.Empty,
            TieneClu = cliente.CredencialCLU is not null,
            NumeroLegajoClu = cliente.CredencialCLU?.NumeroLegajo ?? string.Empty,
            FechaEmisionClu = cliente.CredencialCLU?.FechaEmision,
            FechaVencimientoClu = cliente.CredencialCLU?.FechaVencimiento
        };
    }

    private static string? NormalizarTextoOpcional(string? valor)
    {
        var normalizado = valor?.Trim();
        return string.IsNullOrWhiteSpace(normalizado) ? null : normalizado;
    }

    private static string FormatearContacto(Cliente cliente)
    {
        var datos = new[] { cliente.Telefono, cliente.Email, cliente.Domicilio }
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!)
            .ToArray();

        return datos.Length > 0 ? string.Join(" / ", datos) : "-";
    }

    private static string FormatearClu(CredencialCLU? clu)
    {
        if (clu is null || string.IsNullOrWhiteSpace(clu.NumeroLegajo))
        {
            return "-";
        }

        if (!clu.FechaVencimiento.HasValue)
        {
            return clu.NumeroLegajo;
        }

        var estado = clu.EstaVigente ? "vigente" : "vencida";
        return $"{clu.NumeroLegajo} - {estado} hasta {clu.FechaVencimiento:dd/MM/yyyy}";
    }

    private sealed class ClienteForm
    {
        public int? Id { get; set; }

        [MaxLength(160)]
        public string NombreRazonSocial { get; set; } = string.Empty;

        [MaxLength(20)]
        public string DniCuit { get; set; } = string.Empty;

        [MaxLength(180)]
        public string Email { get; set; } = string.Empty;

        [MaxLength(40)]
        public string Telefono { get; set; } = string.Empty;

        [MaxLength(220)]
        public string Domicilio { get; set; } = string.Empty;

        public bool TieneClu { get; set; }

        [MaxLength(80)]
        public string NumeroLegajoClu { get; set; } = string.Empty;

        public DateOnly? FechaEmisionClu { get; set; }

        public DateOnly? FechaVencimientoClu { get; set; }
    }
}
